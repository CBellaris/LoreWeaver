# LoreWeaver M1 environment template

# LLM providers
OPENAI_API_KEY=
SILICONFLOW_API_KEY=

# Optional storage backends
# Leave QDRANT_URL empty to use local Qdrant storage at data/indexes/qdrant.
QDRANT_URL=
QDRANT_API_KEY=
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=loreweaver-test

# Local runtime
LOREWEAVER_CONFIG=configs/default.yaml
LOREWEAVER_DATA_DIR=data
